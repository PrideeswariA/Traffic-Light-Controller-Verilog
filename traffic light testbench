`timescale 1ns/1ps

module traffic_light_tb;

reg clk;
reg rst;

wire red;
wire yellow;
wire green;

traffic_light DUT(
    .clk(clk),
    .rst(rst),
    .red(red),
    .yellow(yellow),
    .green(green)
);

always #5 clk = ~clk;

initial
begin
    clk = 0;
    rst = 1;

    #10 rst = 0;

    #100;

    $finish;
end

initial
begin
    $monitor("Time=%0t RED=%b YELLOW=%b GREEN=%b",
              $time, red, yellow, green);
end

endmodule
